# ============================================================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in actual values.
# Vite requires the VITE_ prefix for client-side env vars.

# WSO2 Asgardeo (Identity-as-a-Service)
# 1. Sign up at https://asgardeo.io
# 2. Create a Single-Page Application
# 3. Set redirect URL to http://localhost:5173
# 4. Copy your Client ID and Org Name below
VITE_ASGARDEO_CLIENT_ID=
VITE_ASGARDEO_ORG_NAME=your_org_name

# API Base URL (change when routing through WSO2 Gateway)
VITE_API_BASE_URL=/api/v1
