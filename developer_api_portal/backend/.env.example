# ============================================================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in actual values.

# Server
PORT=3000
NODE_ENV=development

# CORS — frontend URL
CORS_ORIGIN=http://localhost:5173

# WSO2 Integration
# Set to 'true' when WSO2 API Manager gateway is running
WSO2_JWT_VALIDATION=false
WSO2_APIM_GATEWAY_URL=https://localhost:8243
WSO2_APIM_PUBLISHER_URL=https://localhost:9443/publisher
WSO2_APIM_DEVPORTAL_URL=https://localhost:9443/devportal

# WSO2 Asgardeo
WSO2_ASGARDEO_BASE_URL=https://api.asgardeo.io/t/your_org_name
WSO2_ASGARDEO_CLIENT_ID=

# External API Keys (optional — services have fallback mock data)
WEATHER_API_KEY=
STOCK_API_KEY=
